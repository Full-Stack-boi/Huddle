{
  "manifest_version": 3,
  "name": "Huddle",
  "description": "Watch videos together in real-time sync. Create rooms, invite friends, or share with your Twitch audience.",
  "version": "2.0.0",
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "vendor/socket.io.min.js",
        "scripts/config.js",
        "scripts/state.js",
        "scripts/utils.js",
        "scripts/toast.js",
        "scripts/theme.js",
        "scripts/video-sync.js",
        "scripts/twitch.js",
        "scripts/socket.js",
        "scripts/sidebar.js",
        "scripts/views.js",
        "scripts/init.js"
      ],
      "css": ["styles/huddle.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles/huddle.css"],
      "matches": [
        "https://www.youtube.com/*",
        "https://www.netflix.com/*",
        "https://www.hotstar.com/*",
        "https://www.primevideo.com/*",
        "https://clips.twitch.tv/*"
      ]
    }
  ],
  "permissions": ["scripting", "storage"],
  "externally_connectable": {
    "matches": ["https://*.vercel.app/*", "http://localhost/*"]
  }
}
